@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">

    <div style="font-size:4rem; margin-bottom:16px;">🎧</div>

    <h1 class="display-4 fw-bold mb-3">Moody<span style="color:var(--spotify-green)">List</span></h1>

    <p class="lead mb-2" style="color:#b3b3b3; max-width:520px; margin:0 auto;">
        Scrivi come ti senti – l'AI di Google Gemini analizza il tuo mood e crea
        una playlist personalizzata solo per te.
    </p>

    <hr class="my-5" style="max-width:300px; margin:auto;" />

    <div class="d-flex flex-wrap gap-3 justify-content-center mb-5">
        <div class="card p-4 text-center" style="width:180px;">
            <div class="fw-semibold mt-2">AI Powered</div>
            <div class="text-muted" style="font-size:0.8rem;">Google Gemini 2.5 Flash</div>
        </div>
        <div class="card p-4 text-center" style="width:180px;">
            <div class="fw-semibold mt-2">Salva</div>
            <div class="text-muted" style="font-size:0.8rem;">Playlist nei preferiti</div>
        </div>
        <div class="card p-4 text-center" style="width:180px;">
            <div class="fw-semibold mt-2">5 Canzoni</div>
            <div class="text-muted" style="font-size:0.8rem;">Per ogni mood</div>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-3 justify-content-center">
        <a asp-page="/Genera" class="btn btn-primary btn-lg px-5">
            Genera la tua playlist
        </a>
        <a asp-page="/Preferiti" class="btn btn-outline-light btn-lg px-5">
            I miei Preferiti
        </a>
    </div>

</div>
